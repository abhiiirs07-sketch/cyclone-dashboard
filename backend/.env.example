# Google Earth Engine service-account credentials.
# See README.md > "Connect your Earth Engine account" for how to create these.
EE_SERVICE_ACCOUNT=your-service-account@your-project.iam.gserviceaccount.com
EE_PRIVATE_KEY_FILE=./secrets/ee-key.json
EE_PROJECT=your-gcp-project-id

# Comma-separated list of allowed frontend origins for CORS
ALLOWED_ORIGINS=http://localhost:3000
